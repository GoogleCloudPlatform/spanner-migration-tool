-- invalid_table_name
CREATE TABLE "table-with-invalid-chars$%^&" (
    id bigint
);
ALTER TABLE "table-with-invalid-chars$%^&" ADD PRIMARY KEY (id)
-- GoogleSQL
CREATE TABLE `table_with_invalid_chars____` (
    `id` INT64 NOT NULL ,
) PRIMARY KEY (`id`)
-- PostgreSQL
CREATE TABLE table_with_invalid_chars____ (
    id INT8 NOT NULL ,
    PRIMARY KEY (id)
)
==
-- create_table_happy_path
CREATE TABLE test (
    id bigint PRIMARY KEY,
    col text
)
-- GoogleSQL
CREATE TABLE `test` (
    `id` INT64 NOT NULL ,
    `col` STRING(MAX),
) PRIMARY KEY (`id`)
-- PostgreSQL
CREATE TABLE test (
    id INT8 NOT NULL ,
    col VARCHAR(2621440),
    PRIMARY KEY (id)
)
==
-- create_table_mixed_case
CREATE TABLE "MixedCaseTable" (
    "Id" bigint PRIMARY KEY,
    "ColName" text
)
-- GoogleSQL
CREATE TABLE `MixedCaseTable` (
    `Id` INT64 NOT NULL ,
    `ColName` STRING(MAX),
) PRIMARY KEY (`Id`)
-- PostgreSQL
CREATE TABLE "MixedCaseTable" (
    "Id" INT8 NOT NULL ,
    "ColName" VARCHAR(2621440),
    PRIMARY KEY ("Id")
)
==